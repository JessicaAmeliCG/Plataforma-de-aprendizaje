# YourCourse — Variables de Entorno
# Copia este archivo a .env y ajusta los valores antes de ejecutar docker-compose

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=yourcourse
POSTGRES_USER=yourcourse_user
POSTGRES_PASSWORD=yourcourse_secret

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_en_produccion_min32chars
JWT_EXPIRES_IN=7d
